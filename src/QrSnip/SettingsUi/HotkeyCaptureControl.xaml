<UserControl x:Class="QrSnip.SettingsUi.HotkeyCaptureControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             FocusVisualStyle="{x:Null}">
    <Border x:Name="CaptureBorder"
            BorderThickness="1"
            BorderBrush="#808080"
            Background="#F8F8F8"
            CornerRadius="3"
            Padding="8,6"
            Cursor="IBeam">
        <StackPanel Orientation="Vertical">
            <TextBlock x:Name="DisplayText"
                       FontFamily="Consolas"
                       FontSize="14"
                       Text="(none)" />
            <TextBlock x:Name="StatusText"
                       FontSize="11"
                       Foreground="#A00000"
                       Visibility="Collapsed"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</UserControl>
